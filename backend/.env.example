GEMINI_API_KEY=your_gemini_api_key_here
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/agri_allied?retryWrites=true&w=majority
JWT_SECRET=your_jwt_signing_secret_here

# Week 6 — Google OAuth (create credentials at https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Frontend URL used for OAuth callback redirect and CORS
FRONTEND_URL=http://localhost:5173

# Optional — SMTP for Forgot Password emails (leave blank to log reset links to console instead)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM=no-reply@agriallied.org
# Base URL of this backend as seen from the browser (must match the
# Authorized Redirect URI registered in Google Cloud Console)
SERVER_URL=http://localhost:5000
